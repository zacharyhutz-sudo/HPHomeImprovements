---
import '../styles/global.css';
import { contact, links } from '../data/siteData.js';
const { title = 'HP Home Improvements' } = Astro.props;
const path = Astro.url.pathname;
const nav = [
  { href: '/', label: 'Home' },
  { href: '/projects/', label: 'Projects' },
  { href: '/services/', label: 'Services' },
  { href: '/vendors/', label: 'Vendors' },
];
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="HP Home Improvements | A contractor for the whole project." />
  </head>
  <body>
    <header class="site-header">
      <div class="topline">
        <a class="brand" href="/">HP Home Improvements</a>
        <a class="phone" href={`tel:${contact.phone.replaceAll('-', '')}`}>{contact.phone}</a>
      </div>
      <nav class="nav" aria-label="Main navigation">
        {nav.map((item) => <a class:list={[{ active: path === item.href || (item.href !== '/' && path.startsWith(item.href)) }]} href={item.href}>{item.label}</a>)}
        <button class="more" type="button" aria-label="More menu">More</button>
      </nav>
      <div class="utility-row">
        <a href={links.instagram} aria-label="Instagram" class="social">◎</a>
        <a href={links.facebook} aria-label="Facebook" class="social">f</a>
        <a href={links.login} class="login">Log In</a>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="footer">
      <a href={`tel:${contact.phone.replaceAll('-', '')}`} class="footer-phone">{contact.phone}</a>
      <div class="footer-socials">
        <a href={links.instagram}>Instagram</a>
        <a href={links.facebook}>Facebook</a>
      </div>
      <p>©2020 by HP Home Improvements. Proudly created with Wix.com</p>
    </footer>
  </body>
</html>
