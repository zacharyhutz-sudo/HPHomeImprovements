---
import { withBase } from '../utils/paths.js';
import '../styles/global.css';
import { brand, contact, links } from '../data/siteData.js';
const {
  title = 'HP Home Improvements',
  description = 'HP Home Improvements is a licensed, bonded, and insured Georgia contractor for the whole project.',
} = Astro.props;
const path = Astro.url.pathname;
const basePath = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');
const currentPath = basePath && path.startsWith(basePath) ? path.slice(basePath.length) || '/' : path;
const nav = [
  { href: '/', label: 'Home' },
  { href: '/projects/', label: 'Projects' },
  { href: '/services/', label: 'Services' },
  { href: '/vendors/', label: 'Vendors' },
  { href: '/#contact', label: 'Contact' },
];
const cleanPhone = contact.phone.replaceAll('-', '');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#060912" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={withBase(brand.logo)} />
    <link rel="icon" href={withBase("/favicon.ico")} sizes="any" />
    <link rel="icon" type="image/png" href={withBase("/favicon-32.png")} />
    <link rel="apple-touch-icon" href={withBase("/apple-touch-icon.png")} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Source+Serif+4:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header" id="site-header">
      <a class="brand" href={withBase("/")} aria-label="HP Home Improvements home">
        <span class="brand-logo-wrap"><img src={withBase(brand.logo)} alt="HP Home Improvements logo" /></span>
        <span class="brand-text">
          <strong>HP Home Improvements</strong>
          <em>{brand.tagline}</em>
        </span>
      </a>

      <nav class="nav" aria-label="Main navigation">
        {nav.map((item) => (
          <a
            href={withBase(item.href)}
            class:list={[{ active: currentPath === item.href || (item.href !== '/' && item.href !== '/#contact' && currentPath.startsWith(item.href)) }]}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="header-actions">
        <a class="ghost-link" href={links.login}>Log In</a>
        <a class="phone-pill" href={`tel:${cleanPhone}`}>{contact.phone}</a>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-grid">
        <div>
          <a class="footer-brand" href={withBase("/")}>
            <img src={withBase(brand.logo)} alt="HP Home Improvements logo" />
          </a>
          <p>{brand.tagline}</p>
        </div>
        <div>
          <h2>Contact</h2>
          <a href={`tel:${cleanPhone}`}>{contact.phone}</a>
          <a href={`mailto:${contact.email}`}>{contact.email}</a>
          <span>{contact.address}</span>
          <span>Fax: {contact.fax}</span>
        </div>
        <div>
          <h2>Explore</h2>
          <a href={withBase("/projects/")}>Projects</a>
          <a href={withBase("/services/")}>Services</a>
          <a href={withBase("/vendors/")}>Vendors</a>
          <a href={links.instagram}>Instagram</a>
          <a href={links.facebook}>Facebook</a>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© {new Date().getFullYear()} HP Home Improvements. All rights reserved.</span>
        <span>Licensed, bonded, and insured in Georgia.</span>
      </div>
    </footer>
  </body>
</html>
