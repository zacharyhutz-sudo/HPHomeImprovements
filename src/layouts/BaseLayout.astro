---
import '../styles/global.css';
import { brand, contact } from '../data/siteData.js';
const {
  title = 'HP Home Improvements',
  description = 'HP Home Improvements is a licensed, bonded, and insured Georgia contractor for the whole project.',
} = Astro.props;
const path = Astro.url.pathname;
const base = import.meta.env.BASE_URL;
const route = (href) => {
  if (href.startsWith('http') || href.startsWith('mailto:') || href.startsWith('tel:')) return href;
  if (href.startsWith('#')) return `${base}${href}`;
  return `${base}${href.replace(/^\/+/, '')}`;
};
const asset = (src) => src.startsWith('http') ? src : `${base}${src.replace(/^\/+/, '')}`;
const nav = [
  { href: '/', label: 'Home' },
  { href: '/projects/', label: 'Projects' },
  { href: '/services/', label: 'Services' },
  { href: '/vendors/', label: 'Vendors' },
  { href: '/#contact', label: 'Contact' },
];
const cleanPhone = contact.phone.replaceAll('-', '');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#15120e" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={asset(brand.logo)} />
    <link rel="icon" href={route('/favicon.ico')} sizes="any" />
    <link rel="icon" type="image/png" href={route('/favicon-32.png')} />
    <link rel="apple-touch-icon" href={route('/apple-touch-icon.png')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Newsreader:opsz,wght@6..72,400;6..72,500;6..72,600;6..72,700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header" id="site-header">
      <a class="brand" href={route('/')} aria-label="HP Home Improvements home">
        <span class="brand-logo-wrap"><img src={asset(brand.logo)} alt="HP Home Improvements logo" /></span>
        <span class="brand-text">
          <strong>HP Home Improvements</strong>
          <em>{brand.tagline}</em>
        </span>
      </a>

      <nav class="nav" aria-label="Main navigation">
        {nav.map((item) => (
          <a
            href={route(item.href)}
            class:list={[{ active: path === route(item.href) || (item.href !== '/' && item.href !== '/#contact' && path.endsWith(item.href)) }]}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="header-actions">
        <a class="phone-link" href={`tel:${cleanPhone}`}>{contact.phone}</a>
        <a class="estimate-pill" href={route('/#contact')}>Request Estimate</a>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-grid">
        <div>
          <a class="footer-brand" href={route('/')}>
            <img src={asset(brand.logo)} alt="HP Home Improvements logo" />
          </a>
          <p>Home improvements, remodels, repairs, and project coordination across Georgia.</p>
        </div>
        <div>
          <h2>Contact</h2>
          <a href={`tel:${cleanPhone}`}>{contact.phone}</a>
          <a href={`mailto:${contact.email}`}>{contact.email}</a>
          <span>{contact.address}</span>
          <span>Fax: {contact.fax}</span>
        </div>
        <div>
          <h2>Explore</h2>
          <a href={route('/projects/')}>Projects</a>
          <a href={route('/services/')}>Services</a>
          <a href={route('/vendors/')}>Vendors</a>
          <a href={route('/#contact')}>Contact</a>
        </div>
      </div>
      <div class="footer-bottom">
        <span>© {new Date().getFullYear()} HP Home Improvements. All rights reserved.</span>
        <span>Licensed, bonded, and insured in Georgia.</span>
      </div>
    </footer>
  </body>
</html>
