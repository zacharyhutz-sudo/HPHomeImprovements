---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/paths.js';
import { brand, contact, homeImages, projectGalleries, processSteps, services } from '../data/siteData.js';
const cleanPhone = contact.phone.replaceAll('-', '');
const featuredProjects = [
  ...projectGalleries[0].images.slice(0, 2),
  ...projectGalleries[1].images.slice(0, 2),
  ...projectGalleries[2].images.slice(0, 2),
];
const featuredServices = services.slice(0, 6);
---
<BaseLayout
  title="HP Home Improvements | Whole-Project Contractor in Georgia"
  description="HP Home Improvements is a licensed, bonded, and insured Georgia contractor for remodels, kitchens, bathrooms, carpentry, exterior work, and more."
>
  <section class="hero home-hero">
    <img src={homeImages[0].src} alt={homeImages[0].alt} class="hero-bg" loading="eager" />
    <div class="hero-overlay"></div>
    <div class="hero-content reveal-up">
      <p class="eyebrow">Licensed • Bonded • Insured</p>
      <h1>A contractor for the whole project.</h1>
      <p class="hero-copy">Home improvements, remodels, carpentry, and project coordination across Georgia.</p>
      <div class="hero-buttons">
        <a class="button button-primary" href="#contact">Book an Estimate</a>
        <a class="button button-secondary" href={withBase("/projects/")}>View Projects</a>
      </div>
    </div>
    <div class="hero-card">
      <img src={withBase(brand.logo)} alt="HP Home Improvements logo" />
      <span>Georgia-based construction services with one clear point of contact from start to finish.</span>
    </div>
  </section>

  <section class="trust-strip" aria-label="Company credentials">
    <div><strong>Licensed</strong><span>Georgia contractor</span></div>
    <div><strong>Bonded</strong><span>Protected projects</span></div>
    <div><strong>Insured</strong><span>Built responsibly</span></div>
    <div><strong>Whole Project</strong><span>Plan, build, finish</span></div>
  </section>

  <section class="split-section">
    <div class="split-image framed-image">
      <img src={homeImages[1].src} alt={homeImages[1].alt} loading="lazy" />
    </div>
    <div class="split-copy">
      <p class="eyebrow blue">About HP</p>
      <h2>One team guiding the work from first estimate to final walkthrough.</h2>
      <p>HP Home Improvements is a leader in providing value-added construction services to customers by creating a successful partnership throughout the construction process. We are a licensed, bonded, and insured company working in the state of Georgia.</p>
      <div class="mini-grid">
        <div>
          <h3>Clear Scope</h3>
          <p>Projects are organized around the actual work, timeline, materials, and finished result.</p>
        </div>
        <div>
          <h3>Craft-Focused</h3>
          <p>From framing to finishes, the details are handled with pride and practical experience.</p>
        </div>
      </div>
      <a class="text-link" href={withBase("/services/")}>See what we do</a>
    </div>
  </section>

  <section class="dark-section services-preview">
    <div class="section-heading centered light">
      <p class="eyebrow">Services</p>
      <h2>Home improvement work with the whole project in view.</h2>
      <p>Renovations often involve more than one trade. HP helps connect the dots so every phase works together.</p>
    </div>
    <div class="card-grid service-grid-preview">
      {featuredServices.map((service) => (
        <a class="service-tile" href={withBase("/services/")}>
          <img src={service.src} alt={`${service.title} service`} loading="lazy" />
          <div>
            <span>Service</span>
            <h3>{service.title}</h3>
            <p>{service.short}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="process-section">
    <div class="section-heading">
      <p class="eyebrow blue">Process</p>
      <h2>Built around a cleaner experience.</h2>
    </div>
    <div class="process-grid">
      {processSteps.map((step, index) => (
        <article>
          <span>{String(index + 1).padStart(2, '0')}</span>
          <h3>{step.title}</h3>
          <p>{step.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="portfolio-preview">
    <div class="section-heading with-link">
      <div>
        <p class="eyebrow blue">Recent Work</p>
        <h2>Selected project details.</h2>
      </div>
      <a class="text-link" href={withBase("/projects/")}>View all projects</a>
    </div>
    <div class="modern-gallery">
      {featuredProjects.map((src, index) => (
        <a class:list={["gallery-item", { large: index === 0 || index === 3 }]} href={withBase("/projects/")}>
          <img src={src} alt="HP Home Improvements project" loading="lazy" />
        </a>
      ))}
    </div>
  </section>

  <section class="quote-band">
    <p class="eyebrow">Client Feedback</p>
    <blockquote>“Greg stated many times that their quality is their reputation and he absolutely stands behind that.”</blockquote>
    <cite>— Jessica R.</cite>
  </section>

  <section class="contact-section" id="contact">
    <div class="contact-copy">
      <p class="eyebrow blue">Start a Project</p>
      <h2>Text or call to book an estimate today.</h2>
      <p>Tell us what you want to improve, and we’ll help you think through the next right step.</p>
      <address>
        <a href={`tel:${cleanPhone}`}>{contact.phone}</a>
        <a href={`mailto:${contact.email}`}>{contact.email}</a>
        <span>{contact.address}</span>
        <span>Fax: {contact.fax}</span>
      </address>
    </div>
    <form class="contact-form" action="#contact-submit" aria-label="Contact form placeholder">
      <label>Name<input name="name" placeholder="Your name" /></label>
      <label>Email<input name="email" placeholder="you@example.com" /></label>
      <label>Phone<input name="phone" placeholder="404-000-0000" /></label>
      <label>Project Details<textarea name="message" placeholder="Tell us about your project..."></textarea></label>
      <a href="#contact-submit" class="button button-primary">Submit</a>
      <p>This is a visual placeholder for now. Backend form handling can be added later.</p>
    </form>
  </section>
</BaseLayout>
