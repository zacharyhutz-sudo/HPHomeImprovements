---
import BaseLayout from '../layouts/BaseLayout.astro';
import { brand, contact, homeImages, projectGalleries, processSteps, services } from '../data/siteData.js';
const base = import.meta.env.BASE_URL;
const route = (href) => href.startsWith('#') ? `${base}${href}` : `${base}${href.replace(/^\/+/, '')}`;
const asset = (src) => src.startsWith('http') ? src : `${base}${src.replace(/^\/+/, '')}`;
const cleanPhone = contact.phone.replaceAll('-', '');
const featuredProjects = [
  projectGalleries.find((gallery) => gallery.title === 'Kitchens')?.images[0],
  projectGalleries.find((gallery) => gallery.title === 'Bathrooms')?.images[0],
  projectGalleries.find((gallery) => gallery.title === 'Decks & Exteriors')?.images[0],
  projectGalleries.find((gallery) => gallery.title === 'Living Rooms')?.images[0],
  projectGalleries.find((gallery) => gallery.title === 'Bathrooms')?.images[4],
  projectGalleries.find((gallery) => gallery.title === 'Kitchens')?.images[2],
].filter(Boolean);
const featuredServices = services.slice(0, 6);
---
<BaseLayout
  title="HP Home Improvements | Whole-Project Contractor in Georgia"
  description="HP Home Improvements is a licensed, bonded, and insured Georgia contractor for remodels, kitchens, bathrooms, carpentry, exterior work, and more."
>
  <section class="hero home-hero">
    <img src={asset(homeImages[0].src)} alt={homeImages[0].alt} class="hero-bg" loading="eager" />
    <div class="hero-overlay"></div>
    <div class="hero-content reveal-up">
      <p class="eyebrow">Licensed • Bonded • Insured</p>
      <h1>Thoughtful home improvements, built with care.</h1>
      <p class="hero-copy">Bathrooms, kitchens, decks, closets, living spaces, and full-project coordination across Georgia.</p>
      <div class="hero-buttons">
        <a class="button button-primary" href={route('/#contact')}>Request an Estimate</a>
        <a class="button button-secondary" href={route('/projects/')}>View Projects</a>
      </div>
    </div>
  </section>

  <section class="trust-strip" aria-label="Company credentials">
    <div><strong>Licensed</strong><span>Georgia contractor</span></div>
    <div><strong>Bonded</strong><span>Protected projects</span></div>
    <div><strong>Insured</strong><span>Built responsibly</span></div>
    <div><strong>Whole Project</strong><span>Plan, build, finish</span></div>
  </section>

  <section class="editorial-intro">
    <div>
      <p class="eyebrow">Our Philosophy</p>
      <h2>Home improvement should feel organized, honest, and well-managed from the first conversation to the final walkthrough.</h2>
    </div>
    <p>HP Home Improvements helps homeowners move from idea to finished project with a clear scope, reliable communication, and careful craftsmanship. We coordinate the details so each phase supports the next.</p>
  </section>

  <section class="split-section philosophy-section">
    <div class="split-image framed-image">
      <img src={asset(homeImages[1].src)} alt={homeImages[1].alt} loading="lazy" />
    </div>
    <div class="split-copy">
      <p class="eyebrow">Built Around Trust</p>
      <h2>One team guiding the work from first estimate to final walkthrough.</h2>
      <p>As a licensed, bonded, and insured company working in Georgia, HP brings practical planning and finish-minded craftsmanship to home improvements, remodels, repairs, and project coordination.</p>
      <div class="mini-grid">
        <div>
          <h3>Clear Scope</h3>
          <p>Projects are organized around the actual work, timeline, materials, and finished result.</p>
        </div>
        <div>
          <h3>Craft-Focused</h3>
          <p>From framing to finishes, the details are handled with pride and practical experience.</p>
        </div>
      </div>
      <a class="text-link" href={route('/services/')}>See what we do</a>
    </div>
  </section>

  <section class="portfolio-preview featured-work-section">
    <div class="section-heading with-link">
      <div>
        <p class="eyebrow">Featured Projects</p>
        <h2>Recent work, finished with care.</h2>
        <p>A closer look at kitchens, bathrooms, exterior work, closets, and living spaces.</p>
      </div>
      <a class="text-link" href={route('/projects/')}>View all projects</a>
    </div>
    <div class="editorial-mosaic">
      {featuredProjects.map((src, index) => (
        <a class:list={["mosaic-item", { feature: index === 0, tall: index === 2 || index === 4 }]} href={route('/projects/')}>
          <img src={asset(src)} alt="HP Home Improvements project" loading="lazy" />
        </a>
      ))}
    </div>
  </section>

  <section class="services-editorial">
    <div class="section-heading centered">
      <p class="eyebrow">Services</p>
      <h2>Renovations with the whole project in view.</h2>
      <p>From finish details to multi-trade coordination, HP helps connect the dots so every phase works together.</p>
    </div>
    <div class="service-list-editorial">
      {featuredServices.map((service, index) => (
        <a class="service-row" href={route('/services/')}>
          <span>{String(index + 1).padStart(2, '0')}</span>
          <h3>{service.title}</h3>
          <p>{service.short}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="process-section">
    <div class="section-heading">
      <p class="eyebrow">Process</p>
      <h2>Built around a cleaner experience.</h2>
    </div>
    <div class="process-grid">
      {processSteps.map((step, index) => (
        <article>
          <span>{String(index + 1).padStart(2, '0')}</span>
          <h3>{step.title}</h3>
          <p>{step.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="quote-band">
    <p class="eyebrow">Client Feedback</p>
    <blockquote>“Greg stated many times that their quality is their reputation and he absolutely stands behind that.”</blockquote>
    <cite>— Jessica R.</cite>
  </section>

  <section class="contact-section" id="contact">
    <div class="contact-copy">
      <p class="eyebrow">Start a Project</p>
      <h2>Text or call to book an estimate today.</h2>
      <p>Tell us what you want to improve, and we’ll help you think through the next right step.</p>
      <address>
        <a href={`tel:${cleanPhone}`}>{contact.phone}</a>
        <a href={`mailto:${contact.email}`}>{contact.email}</a>
        <span>{contact.address}</span>
        <span>Fax: {contact.fax}</span>
      </address>
    </div>
    <form class="contact-form" action="#contact-submit" aria-label="Contact form placeholder">
      <label>Name<input name="name" placeholder="Your name" /></label>
      <label>Email<input name="email" placeholder="you@example.com" /></label>
      <label>Phone<input name="phone" placeholder="404-000-0000" /></label>
      <label>Project Details<textarea name="message" placeholder="Tell us about your project..."></textarea></label>
      <a href="#contact-submit" class="button button-primary">Submit</a>
      <p>This is a visual placeholder for now. Backend form handling can be added later.</p>
    </form>
  </section>
</BaseLayout>
