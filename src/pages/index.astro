---
import BaseLayout from '../layouts/BaseLayout.astro';
import { contact, homeImages } from '../data/siteData.js';
---
<BaseLayout title="General Contractor | HP Home Improvements">
  <section class="hero hero-home">
    <div class="hero-logo" aria-hidden="true">HP</div>
    <h1>HP Home Improvements</h1>
    <p>A contractor for the whole&nbsp;project.</p>
  </section>

  <section class="image-grid home-gallery" aria-label="Home gallery">
    {homeImages.map((image) => <img src={image.src} alt={image.alt} loading="lazy" />)}
  </section>

  <section class="center-section about">
    <h2>About Us</h2>
    <p>HP Home Improvements is a leader in providing value-added construction services to our customers by creating a successful partnership throughout the construction process. We are a licensed, bonded and insured company working in the state of Georgia.</p>
  </section>

  <section class="contact-block">
    <h2>Contact Us</h2>
    <p class="subhead">Text or Call to book an estimate today!</p>
    <address>
      <span>{contact.address}</span>
      <a href={`mailto:${contact.email}`}>{contact.email}</a>
      <a href={`tel:${contact.phone.replaceAll('-', '')}`}>{contact.phone}</a>
      <span>Fax: {contact.fax}</span>
    </address>
    <div class="contact-form fake-form" aria-label="Contact form placeholder">
      <input placeholder="Name" />
      <input placeholder="Email" />
      <input placeholder="Phone" />
      <textarea placeholder="Type your message here..."></textarea>
      <a href="#contact-submit" class="button">Submit</a>
    </div>
  </section>
</BaseLayout>
