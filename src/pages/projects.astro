---
import { withBase } from '../utils/paths.js';
import BaseLayout from '../layouts/BaseLayout.astro';
import { links, projectGalleries, projectsHero } from '../data/siteData.js';
---
<BaseLayout
  title="Projects | HP Home Improvements"
  description="View HP Home Improvements project work across bathrooms, closets, decks, kitchens, living rooms, and more."
>
  <section class="page-hero projects-page-hero">
    <img src={withBase(projectsHero.src)} alt={projectsHero.alt} class="hero-bg" loading="eager" />
    <div class="hero-overlay"></div>
    <div class="page-hero-content">
      <p class="eyebrow">Projects</p>
      <h1>Finished work, real homes, and practical craftsmanship.</h1>
      <p>Browse recent bathrooms, closets, decks, kitchens, and living room work from HP Home Improvements.</p>
    </div>
  </section>

  <section class="projects-intro-panel">
    <div>
      <p class="eyebrow blue">Project Gallery</p>
      <h2>Modern upgrades across the rooms people use every day.</h2>
    </div>
    <p>Each section below uses the new WebP project uploads from <code>public/assets/projects</code>, organized by filename prefix: BR, C, D, K, and L.</p>
  </section>

  <section class="project-category-nav" aria-label="Project categories">
    {projectGalleries.map((gallery) => (
      <a href={`#${gallery.slug}`}>
        <span>{gallery.title}</span>
        <strong>{gallery.images.length}</strong>
      </a>
    ))}
  </section>

  {projectGalleries.map((gallery) => (
    <section class="project-gallery-section project-mosaic-section" id={gallery.slug}>
      <div class="section-heading with-link">
        <div>
          <p class="eyebrow blue">{gallery.label}</p>
          <h2>{gallery.title}</h2>
          <p>{gallery.kicker}</p>
        </div>
        <a class="text-link" href={withBase("/#contact")}>Plan a similar project</a>
      </div>
      <div class="project-mosaic-grid">
        {gallery.images.map((image, index) => (
          <a
            class:list={[
              'project-image-card',
              {
                feature: index === 0,
                wide: index === 3 || index === 8 || index === 13,
                tall: index === 2 || index === 6 || index === 11 || gallery.images.length === 2,
              },
            ]}
            href={withBase(image.src)}
            aria-label={`Open ${image.alt}`}
          >
            <img src={withBase(image.src)} alt={image.alt} loading="lazy" />
            <span>{String(index + 1).padStart(2, '0')}</span>
          </a>
        ))}
      </div>
    </section>
  ))}

  <section class="testimonial-feature">
    <div class="testimonial-card-modern">
      <p class="eyebrow blue">What Clients Say</p>
      <h2>“Their quality is their reputation.”</h2>
      <p>We've used HP Home Improvements three times in the past six months, most recently to do a complete renovation of our master bathroom. Each project has been completed timely and Greg and his crew were easy and professional to work with.</p>
      <p>They really outdid themselves with our master bath and we couldn't be happier with how it turned out!</p>
      <cite>Jessica R.</cite>
    </div>
    <div class="testimonial-aside">
      <span>5★</span>
      <p>Clean work, reliable communication, and a project experience that keeps the finish line in focus.</p>
      <a class="text-link" href={links.yelp}>Read Yelp Reviews</a>
    </div>
  </section>

  <section class="review-form-section">
    <div>
      <p class="eyebrow blue">Add a Testimonial</p>
      <h2>How did we do?</h2>
      <p>This is a placeholder form for now. It can be wired to a form service later.</p>
    </div>
    <form class="contact-form compact" action="#testimonial-submit">
      <label>Your Review<textarea name="review" placeholder="Share your experience..."></textarea></label>
      <fieldset>
        <legend>Would you recommend us to your friends?</legend>
        <label class="radio-line"><input type="radio" name="recommend" /> Yes</label>
        <label class="radio-line"><input type="radio" name="recommend" /> No</label>
      </fieldset>
      <a href="#testimonial-submit" class="button button-primary">Submit</a>
    </form>
  </section>
</BaseLayout>
