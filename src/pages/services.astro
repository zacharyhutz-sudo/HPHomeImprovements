---
import BaseLayout from '../layouts/BaseLayout.astro';
import { contact, homeImages, processSteps, services } from '../data/siteData.js';
const base = import.meta.env.BASE_URL;
const route = (href) => href.startsWith('#') ? `${base}${href}` : `${base}${href.replace(/^\/+/, '')}`;
const asset = (src) => src.startsWith('http') ? src : `${base}${src.replace(/^\/+/, '')}`;
const cleanPhone = contact.phone.replaceAll('-', '');
---
<BaseLayout
  title="Services | HP Home Improvements"
  description="Explore HP Home Improvements services including kitchens, bathrooms, decks, exterior work, carpentry, closets, and living spaces."
>
  <section class="page-hero">
    <img src={asset(homeImages[2].src)} alt={homeImages[2].alt} class="hero-bg" loading="eager" />
    <div class="hero-overlay"></div>
    <div class="page-hero-content">
      <p class="eyebrow">Services</p>
      <h1>Home improvement services from start to finish.</h1>
      <p>Renovations are easier when the plan, trades, materials, and finish work are moving in the same direction.</p>
    </div>
  </section>

  <section class="services-showcase">
    {services.map((service, index) => (
      <article class:list={["service-feature", { reverse: index % 2 === 1 }]}> 
        <div class="service-image">
          <img src={asset(service.src)} alt={`${service.title} service`} loading="lazy" />
        </div>
        <div class="service-detail">
          <p class="eyebrow">{String(index + 1).padStart(2, '0')}</p>
          <h2>{service.title}</h2>
          <p class="lead">{service.short}</p>
          <p>{service.detail}</p>
          <a class="text-link" href={route('/#contact')}>Request an estimate</a>
        </div>
      </article>
    ))}
  </section>

  <section class="dark-section process-dark">
    <div class="section-heading centered light">
      <p class="eyebrow">How We Work</p>
      <h2>One contractor. One plan. One finished project.</h2>
    </div>
    <div class="process-grid light-grid">
      {processSteps.map((step, index) => (
        <article>
          <span>{String(index + 1).padStart(2, '0')}</span>
          <h3>{step.title}</h3>
          <p>{step.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="cta-split">
    <div>
      <p class="eyebrow">Ready to Talk?</p>
      <h2>Bring us the whole project, or the part that needs a clear next step.</h2>
    </div>
    <a class="button button-primary" href={`tel:${cleanPhone}`}>Call {contact.phone}</a>
  </section>
</BaseLayout>
