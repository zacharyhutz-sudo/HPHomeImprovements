---
import BaseLayout from '../layouts/BaseLayout.astro';
import { services } from '../data/siteData.js';
---
<BaseLayout title="Services | HP Home Improvements">
  <section class="services-page">
    <div class="services-grid">
      {services.map((service, index) => (
        <article class:list={["service-card", { reverse: index % 2 === 1 }]}>
          <img src={service.src} alt={`${service.title} service`} loading="lazy" />
          <div>
            <h1 class={index === 0 ? '' : 'as-h2'}>{service.title}</h1>
            <p>{service.text}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
