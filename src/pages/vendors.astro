---
import BaseLayout from '../layouts/BaseLayout.astro';
import { vendors } from '../data/siteData.js';
---
<BaseLayout title="Vendors | HP Home Improvements">
  <section class="vendor-intro">
    <h1>Vendor List</h1>
    <p>Companies We Love to Partner With</p>
  </section>
  <section class="vendor-list">
    {vendors.map((vendor) => (
      <article class="vendor-card">
        <a href={vendor.url} class:list={["vendor-mark", vendor.type]}>
          {vendor.mark.split('\n').map((line) => <span>{line}</span>)}
        </a>
        <h2>{vendor.name}</h2>
        <a href={vendor.url}>Website</a>
      </article>
    ))}
  </section>
</BaseLayout>
